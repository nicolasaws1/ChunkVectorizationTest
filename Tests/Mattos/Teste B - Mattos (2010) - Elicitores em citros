]

print(f"\n{'='*60}")
print(f"🔍 RESULTADOS — TESTE B (512 + Overlap 128) ✅")
print(f"   Perguntas em português | Texto em português")
print(f"   Modelo: Qwen3-Embedding-0.6B (multilingual)")
print(f"{'='*60}")

scores_B = []
for pergunta in perguntas:
    r         = buscar_faiss(pergunta, index_B, chunks)
    relevante = "✅" if r['score'] > 0.55 else "⚠️" if r['score'] > 0.45 else "❌"
    scores_B.append(r['score'])
