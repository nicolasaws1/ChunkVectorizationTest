    print(f"   Score : {r['score']:.4f} {relevante} | Chars: {r['chars']}")
    print(f"   Texto : {r['chunk'][:200]}...")
    print("-"*60)

media_score = sum(scores_B)/len(scores_B)
print(f"\n📈 MÉDIA  : {media_score:.4f}")
